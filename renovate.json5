{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    "group:allNonMajor",
    "customManagers:dockerfileVersions",
    ":separateMajorReleases"
  ],
  "customManagers": [
    // Repology dependencies
    {
      "customType": "regex",
      "managerFilePatterns": [
        "*/config.yaml",
        "*/Dockerfile"
      ],
      "matchStrings": [
        "(^|\\n)#\\s*renovate:\\s*datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>.*?))?\\r?\\nversion:\\s+(?<currentValue>\\S+)-\\d+($|\\r?\\n)",
        "(^|\\n)#\\s*renovate:\\s*datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>.*?))?\\r?\\nENV .*?_VERSION=\"?(?<currentValue>\\S+)\"?($|\\r?\\n)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    // Repo version in Repology
    {
      "customType": "regex",
      "managerFilePatterns": [
        "*/config.yaml",
        "*/Dockerfile"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=repology depName=(?<depName>[^_]+)_(?<currentValue>[\\d_]+)\\/"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "regex:^(?<major>\\d+)_(?<minor>\\d+)$",
      "extractVersionTemplate": "^(?<major>\\d+).(?<minor>\\d+).(?<patch>\\d+)$"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "{{{replace '^.*/' '' packageName}}}"
      ]
    }
  ]
}
